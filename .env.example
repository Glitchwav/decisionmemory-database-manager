# DecisionMemory Protocol — Environment Variables
# Copy this file to .env and fill in your values

# ── Core ───────────────────────────────────────────
# DecisionMemory API endpoint (for REST API mode)
DECISIONMEMORY_API=http://localhost:8000

# ── Optional ───────────────────────────────────────
# Anthropic API Key (for evolution engine, replay, reflections)
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Daily reflection output directory
REFLECTION_OUTPUT_DIR=reflections

# Discord Webhook (decision sync + daily report notifications)
# Create at: Discord Server Settings → Integrations → Webhooks → New Webhook
DISCORD_WEBHOOK_URL=

# ── MT5 Integration (optional) ─────────────────────
# Only needed if syncing decisions from MetaDecisionMaker 5
MT5_LOGIN=your_login_here
MT5_PASSWORD=your_password_here
MT5_SERVER=YourProvider-Server

# MT5 Terminal Path (auto-detect if not set)
MT5_PATH=C:\Program Files\MetaDecisionMaker 5\terminal64.exe

# Sync interval in seconds
SYNC_INTERVAL=60

# === Optional SurrealDB Secondary Store ===
# SQLite is always the authoritative application database.
# Optional fail-open graph copy; failures never roll back SQLite.
# Leave empty/disabled (default), or set to 'surreal'.
DECISIONMEMORY_SECONDARY_STORE=

# SurrealDB connection (defaults to localhost:8000, unauthenticated)
SURREAL_HOST=http://localhost
SURREAL_PORT=8000
# SURREAL_USER=root
# SURREAL_PASS=root
SURREAL_NS=antigravity
SURREAL_DB=unified
